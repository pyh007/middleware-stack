# 仅用于本机学习环境；不要在生产复用这些凭据、堆配置或磁盘水位。
ES_VERSION=9.4.3-arm64
ES_PORT=9200
ES_PASSWORD=elastic-local-123
ES_JAVA_OPTS=-Xms512m -Xmx512m
ES_REQUIRED_DISK_GB=1

# 使用绝对剩余空间水位，适配小型 Docker Desktop 虚拟盘，同时保留保护机制。
ES_DISK_WATERMARK_LOW=1536mb
ES_DISK_WATERMARK_HIGH=1gb
ES_DISK_WATERMARK_FLOOD_STAGE=512mb
ES_MERGE_DISK_WATERMARK_HIGH=512mb

# Kibana 仅在 make up-kibana 时启动，以下均为本地专用值。
KIBANA_PORT=5601
KIBANA_SYSTEM_PASSWORD=kibana-local-123
KIBANA_ENCRYPTION_KEY=local-kibana-encryption-key-32-chars
